# Pin a specific port. If unset, the server tries 3000 first, then scrambles
# to a random port in the IANA dynamic range (49152–65535).
# PORT=3000

# Just change the first-try port without losing the scramble fallback.
# PREFERRED_PORT=4000

# Lock down the admin/reports/projects/screenshots endpoints. If unset,
# admin is open (dev mode). Generate one with: openssl rand -hex 16
# FEEDBACK_ADMIN_TOKEN=

# Zoho OAuth — register a "Server-based Application" at
# https://api-console.zoho.com, set its redirect URI to
#   {FEEDBACK_BASE_URL}/admin/api/oauth/zoho/callback
# and paste the client id + secret here. Once these are set, admin gets a
# one-click "Connect Zoho" button per connector instead of asking for refresh
# tokens manually, and portal/project/tasklist pickers populate automatically.
# FEEDBACK_ZOHO_CLIENT_ID=
# FEEDBACK_ZOHO_CLIENT_SECRET=

# Public URL the admin is reachable at (used to build the OAuth redirect URI).
# If unset, we derive it from the inbound request — fine in dev, set explicitly
# behind a reverse proxy.
# FEEDBACK_BASE_URL=https://feedback.example.com
